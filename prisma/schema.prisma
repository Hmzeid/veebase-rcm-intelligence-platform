generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Claim {
  id                String   @id @default(cuid())
  claimNumber       String   @unique
  patientId         String
  patientName       String
  nationalId        String
  encounterId       String
  payerId           String
  payerName         String
  payerType         String   // NHIA | PRIVATE | SELF_PAY
  serviceDate       DateTime
  totalAmount       Float
  status            String   // ELIGIBILITY | PRIOR_AUTH | CHARGE_CAPTURE | CODING | SCRUBBING | SUBMITTED | ADJUDICATION | REMITTANCE | DENIED | PAID | CLOSED | WRITTEN_OFF
  readinessScore    Int      @default(0)
  denialRiskScore   Int      @default(0)
  priorAuthRequired Boolean  @default(false)
  priorAuthNumber   String?
  priorAuthStatus   String?  // APPROVED | DENIED | PENDING | NOT_REQUIRED
  submittedAt       DateTime?
  expectedResponseBy DateTime?
  paidAmount        Float    @default(0)
  patientResponsibility Float @default(0)
  appealDeadline    DateTime?
  filingDeadline    DateTime?
  phase             Int      @default(1)
  hitlGate          String   @default("REVIEW") // APPROVE | REVIEW | AUTO
  currentAgent      String?
  tags              String   @default("[]") // JSON array of tags
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model AgentStatus {
  id              String   @id @default(cuid())
  agentName       String   @unique
  displayName     String
  description     String
  icon            String
  status          String   @default("IDLE") // ACTIVE | IDLE | ERROR | PROCESSING
  lastActivity    DateTime?
  claimsProcessed Int      @default(0)
  activeClaims    Int      @default(0)
  errorCount      Int      @default(0)
  avgProcessingMs Int      @default(0)
  category        String   // LINEAR | SENTINEL | KNOWLEDGE | ANALYTICS
  sequence        Int      @default(0)
  updatedAt       DateTime @updatedAt
}

model Escalation {
  id              String   @id @default(cuid())
  claimId         String
  claimNumber     String
  level           Int      // 1-5
  reason          String
  agentName       String
  status          String   @default("PENDING") // PENDING | ACKNOWLEDGED | RESOLVED | ESCALATED
  tags            String   @default("[]") // JSON array
  assignedTo      String?
  resolvedAt      DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model KPIRecord {
  id          String   @id @default(cuid())
  name        String
  value       Float
  target      Float
  unit        String   // pct | days | EGP | count
  category    String   // OPERATIONAL | FINANCIAL | QUALITY
  period      String   // DAILY | WEEKLY | MONTHLY
  trend       String   @default("STABLE") // IMPROVING | STABLE | DEGRADING
  recordedAt  DateTime @default(now())
}

// ────────────────────────────────────────────────────────────────────
//  Audit, processing, and integration models (production layer)
// ────────────────────────────────────────────────────────────────────

/// Immutable compliance audit trail — every state change is recorded here.
model AuditLog {
  id            String   @id @default(cuid())
  timestamp     DateTime @default(now())
  action        String   // HITL_APPROVE | HITL_REJECT | ESCALATE | RESOLVE | SUBMIT_CLAIM | APPEAL_FILED | PAYMENT_DISPUTE | PHASE_CHANGE | AGENT_OVERRIDE | CLAIM_CREATED | STATUS_CHANGE | AGENT_RUN
  actor         String
  actorRole     String   @default("System")
  claimId       String?
  claimNumber   String?
  agentName     String?
  details       String
  previousValue String?
  newValue      String?
  riskLevel     String   @default("LOW") // LOW | MEDIUM | HIGH | CRITICAL
  tags          String   @default("[]")  // JSON array
  source        String   @default("ui")  // ui | api | engine | webhook

  @@index([claimId])
  @@index([action])
  @@index([timestamp])
}

/// Per-agent processing output recorded when an agent runs on a claim.
model ClaimEvent {
  id                 String   @id @default(cuid())
  claimId            String
  claimNumber        String
  agentName          String
  phase              Int      @default(1)
  fromStatus         String?
  toStatus           String?
  confidence         String   @default("HIGH") // HIGH | MEDIUM | LOW | INSUFFICIENT_DATA
  rationale          String
  recommendedAction  String
  hitlGate           String   @default("AUTO") // APPROVE | REVIEW | AUTO
  escalationRequired Boolean  @default(false)
  output             String   @default("{}") // JSON payload
  tags               String   @default("[]") // JSON array
  createdAt          DateTime @default(now())

  @@index([claimId])
  @@index([agentName])
}

/// API keys for external systems integrating inbound with the platform.
model ApiKey {
  id          String    @id @default(cuid())
  name        String
  keyHash     String    @unique // sha-256 hash of the secret
  prefix      String    // first 8 chars, shown in UI for identification
  scopes      String    @default("[\"read\",\"write\"]") // JSON array
  active      Boolean   @default(true)
  lastUsedAt  DateTime?
  createdAt   DateTime  @default(now())
  createdBy   String    @default("system")
}

/// Outbound webhook subscriptions — push events to external systems.
model Webhook {
  id          String   @id @default(cuid())
  url         String
  secret      String   // used to HMAC-sign payloads
  events      String   @default("[\"*\"]") // JSON array of event names, or ["*"]
  active      Boolean  @default(true)
  description String   @default("")
  createdAt   DateTime @default(now())
  deliveries  WebhookDelivery[]
}

/// Application users for role-based access control (RBAC).
model User {
  id           String    @id @default(cuid())
  email        String    @unique
  name         String
  passwordHash String
  role         String    @default("VIEWER") // ADMIN | RCM_MANAGER | BILLER | COMPLIANCE | VIEWER
  active       Boolean   @default(true)
  lastLoginAt  DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
}

/// Key/value application settings (e.g. the runtime-selected AI provider).
model Setting {
  key       String   @id
  value     String
  updatedAt DateTime @updatedAt
}

/// Idempotency keys so external systems can safely retry create requests.
model IdempotencyKey {
  id        String   @id @default(cuid())
  key       String   @unique
  scope     String   @default("claim.create")
  claimId   String?
  response  String   @default("{}") // cached JSON response
  createdAt DateTime @default(now())
}

/// Delivery log for each webhook attempt (for retries and observability).
model WebhookDelivery {
  id           String   @id @default(cuid())
  webhookId    String
  webhook      Webhook  @relation(fields: [webhookId], references: [id], onDelete: Cascade)
  event        String
  payload      String   // JSON
  status       String   @default("PENDING") // PENDING | SUCCESS | FAILED
  statusCode   Int?
  responseBody String?
  attempts     Int      @default(0)
  createdAt    DateTime @default(now())
  deliveredAt  DateTime?

  @@index([webhookId])
  @@index([status])
}
